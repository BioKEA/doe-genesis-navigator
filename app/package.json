{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "parse": "tsx scripts/parse.ts",
    "scrape": "tsx scripts/scrape.ts",
    "concepts:extract": "tsx --env-file=.env scripts/concepts/01-extract.ts",
    "concepts:embed": "tsx scripts/concepts/02-embed.ts",
    "concepts:cluster": "tsx scripts/concepts/03-cluster.ts",
    "concepts:label": "tsx --env-file=.env scripts/concepts/04-label.ts",
    "curate": "tsx scripts/concepts/curate.ts",
    "concepts:retag": "tsx --env-file=.env scripts/concepts/05-retag.ts",
    "matches:retag-fields": "tsx --env-file=.env scripts/matches/01-retag-fields.ts",
    "matches:candidates": "tsx scripts/matches/02-candidates.ts",
    "matches:score": "tsx --env-file=.env scripts/matches/03-score.ts",
    "matches:finalize": "tsx scripts/matches/04-finalize.ts",
    "matches": "npm run matches:retag-fields && npm run matches:candidates && npm run matches:score && npm run matches:finalize",
    "concepts": "npm run concepts:extract && npm run concepts:embed && npm run concepts:cluster && npm run concepts:label && echo '\\nNext: run \"npm run curate\" to curate the concept layer, then \"npm run concepts:retag\".'",
    "build": "npm run parse && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "fuse.js": "^7.3.0",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "sigma": "^3.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/density-clustering": "^1.3.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.5.0",
    "density-clustering": "^1.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
